{
  "version": "1.0",
  "defaultAgent": "claude-sonnet-4-20250514",
  "agents": {
    "documentation": {
      "model": "gpt-4-turbo",
      "temperature": 0.3,
      "maxTokens": 8000,
      "description": "For writing, reviewing, and generating documentation",
      "triggers": ["*.md", "docs/**", "README", "CHANGELOG", "API_DOCS"]
    },
    "architecture": {
      "model": "gpt-4-turbo",
      "temperature": 0.2,
      "maxTokens": 12000,
      "description": "For system design, architecture decisions, and technical planning",
      "triggers": [
        "ARCHITECTURE.md",
        "design-system.md",
        "schema.sql",
        ".copilot/architecture/**",
        "decisions/**"
      ]
    },
    "major-features": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.5,
      "maxTokens": 16000,
      "description": "For implementing major features and complex logic",
      "triggers": [
        "src/screens/**",
        "src/api/**",
        "src/hooks/**",
        "app/**",
        "Feature implementation",
        "Complex refactor"
      ]
    },
    "react-native": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.4,
      "maxTokens": 10000,
      "description": "React Native and Expo specific tasks",
      "triggers": [
        "*.tsx",
        "*.jsx",
        "components/**",
        "screens/**",
        "React component",
        "Mobile UI"
      ]
    },
    "backend": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.3,
      "maxTokens": 8000,
      "description": "Backend, API, and database work",
      "triggers": [
        "src/api/**",
        "schema.sql",
        "PostgreSQL",
        "Supabase",
        "RPC function",
        "database migration"
      ]
    },
    "testing": {
      "model": "gpt-4-turbo",
      "temperature": 0.3,
      "maxTokens": 6000,
      "description": "Test writing and QA",
      "triggers": [
        "*.test.ts",
        "*.test.tsx",
        "*.spec.ts",
        "__tests__/**",
        "test/",
        "QA audit"
      ]
    },
    "security": {
      "model": "gpt-4-turbo",
      "temperature": 0.2,
      "maxTokens": 8000,
      "description": "Security audits and vulnerability fixes",
      "triggers": [
        "security",
        "auth",
        "RLS",
        "encryption",
        "vulnerability",
        "auth hardening"
      ]
    },
    "performance": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.3,
      "maxTokens": 8000,
      "description": "Performance optimization and profiling",
      "triggers": [
        "performance",
        "optimization",
        "profiling",
        "memory leak",
        "bundle size"
      ]
    },
    "refactoring": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.4,
      "maxTokens": 10000,
      "description": "Code refactoring and cleanup",
      "triggers": [
        "refactor",
        "cleanup",
        "dead code",
        "migration",
        "deprecation"
      ]
    },
    "debugging": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.5,
      "maxTokens": 8000,
      "description": "Debugging and troubleshooting",
      "triggers": ["debug", "error", "bug fix", "issue", "crash", "TypeError"]
    },
    "tdd": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.4,
      "maxTokens": 12000,
      "description": "Test-driven development workflow",
      "triggers": ["tdd", "test-driven", "TDD workflow"]
    },
    "systematic-debugging": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.3,
      "maxTokens": 8000,
      "description": "Systematic 5-step debugging process",
      "triggers": ["debug-systematic", "debug workflow"]
    },
    "verification": {
      "model": "gpt-4-turbo",
      "temperature": 0.2,
      "maxTokens": 6000,
      "description": "Verification checklist before commit",
      "triggers": ["verify", "verification", "quality gate"]
    },
    "code-review": {
      "model": "gpt-4-turbo",
      "temperature": 0.3,
      "maxTokens": 8000,
      "description": "PR generation and code review",
      "triggers": ["review", "pr-description", "code review"]
    },
    "git-worktree": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.2,
      "maxTokens": 4000,
      "description": "Git worktree setup for parallel work",
      "triggers": ["git-worktree", "parallel work", "worktree"]
    },
    "prompt-analyzer": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.3,
      "maxTokens": 4000,
      "description": "Automatically route natural language prompts to the right skill or agent",
      "triggers": [
        "analyze prompt",
        "which skill",
        "what should I do",
        "help me route",
        "what workflow"
      ]
    },
    "ui-reference-screen-generation": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.6,
      "maxTokens": 16000,
      "description": "Generate screen code from design images, Figma exports, or UI references",
      "triggers": [
        "design image",
        "look at",
        "screens/",
        ".png",
        ".jpg",
        "ui reference",
        "build from design",
        "figma export"
      ]
    }
  },
  "routingRules": [
    {
      "pattern": "(README|CHANGELOG|docs/.*\\.md)$",
      "agent": "documentation",
      "priority": 10
    },
    {
      "pattern": "(ARCHITECTURE|design-system|schema\\.sql)$",
      "agent": "architecture",
      "priority": 9
    },
    {
      "pattern": "designs/.*\\.(png|jpg|jpeg|figma|sketch)$",
      "agent": "ui-reference-screen-generation",
      "priority": 9,
      "description": "Auto-route design images to screen generation"
    },
    {
      "pattern": "src/screens/.*\\.(tsx|ts)$",
      "agent": "react-native",
      "priority": 8
    },
    {
      "pattern": "src/api/.*\\.(tsx|ts)$",
      "agent": "backend",
      "priority": 8
    },
    {
      "pattern": "schema\\.sql|migrations/.*\\.sql$",
      "agent": "backend",
      "priority": 8
    },
    {
      "pattern": ".*\\.test\\.(ts|tsx)$",
      "agent": "testing",
      "priority": 7
    }
  ],
  "commandMatchers": [
    {
      "command": "copilot:docs",
      "agent": "documentation"
    },
    {
      "command": "copilot:architecture",
      "agent": "architecture"
    },
    {
      "command": "copilot:feature",
      "agent": "major-features"
    },
    {
      "command": "copilot:test",
      "agent": "testing"
    },
    {
      "command": "copilot:security",
      "agent": "security"
    },
    {
      "command": "copilot:debug",
      "agent": "debugging"
    },
    {
      "command": "copilot:tdd",
      "agent": "tdd"
    },
    {
      "command": "copilot:debug-systematic",
      "agent": "systematic-debugging"
    },
    {
      "command": "copilot:verify",
      "agent": "verification"
    },
    {
      "command": "copilot:review",
      "agent": "code-review"
    },
    {
      "command": "copilot:git-worktree",
      "agent": "git-worktree"
    },
    {
      "command": "copilot:analyze-prompt",
      "agent": "prompt-analyzer"
    },
    {
      "command": "copilot:ui-reference-screen",
      "agent": "ui-reference-screen-generation"
    },
    {
      "command": "copilot:screen-from-design",
      "agent": "ui-reference-screen-generation"
    }
  ]
}
